---
import { getCollection, render } from 'astro:content'
import type { CollectionEntry } from 'astro:content'
import type { Category, EntryMeta } from '../lib/taxonomy'
import { buildTree, resolveRelated } from '../lib/taxonomy'
import { CATEGORIES, CATEGORY_META } from '../data/categories'
import TreeNav from '../components/TreeNav.astro'
import SearchBar from '../components/SearchBar.astro'
import EntryCard from '../components/EntryCard.astro'
import '../styles/global.css'

type Loaded = { meta: EntryMeta; entry: CollectionEntry<Category>; category: Category }

const loaded: Loaded[] = (
  await Promise.all(
    CATEGORIES.map(async cat => {
      const entries = await getCollection(cat)
      return entries.map(e => ({
        meta: {
          slug: e.id,
          category: cat,
          title: e.data.title,
          subcategory: e.data.subcategory,
          normalizedSubcategory: e.data.subcategory.toLowerCase(),
          skill_level: e.data.skill_level,
          we_use_this: e.data.we_use_this,
          related: e.data.related,
          tags: e.data.tags,
        } satisfies EntryMeta,
        entry: e,
        category: cat,
      }))
    })
  )
).flat()

const allEntries = loaded.map(l => l.meta)
const tree = buildTree(allEntries)

const CATEGORY_DESC: Partial<Record<typeof CATEGORIES[number], string>> = {
  'creative-code': 'Visual frameworks, engines & environments',
  display:         'Projection, LED panels & video distribution',
  'av-tools':      'Show control, audio & lighting protocols',
  physical:        'Microcontrollers, motors & embedded hardware',
  sensors:         'Depth cameras, tracking & computer vision',
  'ai-tools':      'Generative AI, voice synthesis & image tools',
}
const categoryCounts = Object.fromEntries(
  CATEGORIES.map(cat => [cat, allEntries.filter(e => e.category === cat).length])
)

// Safe JSON: escape </script> sequences
const taxonomyJson = JSON.stringify(allEntries).replace(/<\/script>/gi, '<\\/script>')
---

<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>Museum Tech Guide</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;1,300;1,400&family=DM+Mono:ital,wght@0,300;0,400;0,500;1,300&display=swap" rel="stylesheet">
</head>
<body>

<script id="taxonomy-data" type="application/json" set:html={taxonomyJson}></script>

<div id="mobile-browse">☰ Browse</div>

<div id="app">
  <TreeNav tree={tree}>
    <SearchBar slot="search" />
  </TreeNav>

  <div id="main">
    <div id="welcome">
      <div id="welcome-intro">
        <h1>Museum Tech<br/>Guide</h1>
        <p>A reference for the museum's creative technology landscape. Browse tools, protocols, and techniques — or filter by skill level and what the team uses.</p>
      </div>
      <div id="cat-grid">
        {CATEGORIES.map(cat => (
          <div class="cat-card" data-cat={cat}>
            <div class="cat-card-count">{categoryCounts[cat]}</div>
            <div class="cat-card-label">{CATEGORY_META[cat].label}</div>
            <div class="cat-card-desc">{CATEGORY_DESC[cat]}</div>
          </div>
        ))}
      </div>
    </div>

    <div id="cat-view">
      <div id="cat-view-hd">
        <button id="cat-view-back">← Home</button>
        <h1 id="cat-view-title"></h1>
        <p id="cat-view-desc"></p>
      </div>
      <div id="cat-view-entries"></div>
    </div>

    <div id="not-found">
      <h1>Entry not found</h1>
      <p><a href="#" id="back-home">← Back home</a></p>
    </div>

    {loaded.map(({ entry, category, meta }) => (
      <EntryCard
        entry={entry}
        category={category}
        relatedEntries={resolveRelated(meta.related, allEntries)}
      />
    ))}
  </div>
</div>

<script>
  import '../scripts/app'
</script>

</body>
</html>
