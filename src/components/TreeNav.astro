---
import type { TaxonomyTree } from '../lib/taxonomy'
import { serializeHash } from '../lib/taxonomy'
import { CATEGORY_META } from '../data/categories'

interface Props { tree: TaxonomyTree }
const { tree } = Astro.props
---

<nav id="sidebar">
  <div id="sidebar-header"><h2>Museum Tech Guide</h2></div>

  <slot name="search" />

  <div id="search-results" role="listbox"></div>

  <div id="filter-bar">
    <div id="skill-filters">
      <button class="filter-btn" data-skill="beginner">Beginner</button>
      <button class="filter-btn" data-skill="intermediate">Inter.</button>
      <button class="filter-btn" data-skill="advanced">Advanced</button>
      <button id="we-use-filter" class="filter-btn">◆ In use</button>
    </div>
    <div id="filter-meta">
      <div id="skill-legend">
        <span><span class="skill-dot skill-beginner"></span>Beginner</span>
        <span><span class="skill-dot skill-intermediate"></span>Intermediate</span>
        <span><span class="skill-dot skill-advanced"></span>Advanced</span>
      </div>
      <span id="entry-count"></span>
    </div>
  </div>

  <div id="active-tag-bar" hidden>
    <span id="active-tag-label"></span>
    <button id="clear-tag">×</button>
  </div>

  <div class="tree" id="tree">
    {tree.map(node => {
      const meta = CATEGORY_META[node.category]
      return (
        <div class="tree-cat" data-cat={node.category}>
          <div class="tree-cat-hd">
            <span class="tree-toggle">›</span>
            <span>{meta.label}</span>
          </div>
          <div class="tree-children">
            {node.subcategories.map(sub => (
              <div class="tree-sub">
                <div class="tree-sub-hd">
                  <span class="tree-toggle">›</span>
                  <span>{sub.name}</span>
                </div>
                <div class="tree-children">
                  {sub.entries.map(e => (
                    <div
                      class="tree-entry"
                      data-href={serializeHash(e.category, e.slug)}
                      data-skill={e.skill_level}
                      data-we-use={e.we_use_this ? 'true' : 'false'}
                      data-tags={e.tags.join(',')}
                      tabindex="0"
                    >
                      <span class={`skill-dot skill-${e.skill_level}`} title={e.skill_level}></span>
                      {e.we_use_this && <span class="dot" title="We use this" />}
                      {e.title}
                    </div>
                  ))}
                </div>
              </div>
            ))}
          </div>
        </div>
      )
    })}
  </div>
</nav>
